{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GlockRuntimeManagerAPI",
  "description": "API schema for the Runtime Manager (Session Runtime Layer)",

  "definitions": {
    "AllocationRequest": {
      "type": "object",
      "required": ["session_id", "user_id"],
      "properties": {
        "session_id": {
          "type": "string",
          "pattern": "^sess_[a-z0-9]{24}$"
        },
        "user_id": {
          "type": "string",
          "pattern": "^user_[a-z0-9]{24}$"
        },
        "org_id": {
          "type": ["string", "null"],
          "pattern": "^org_[a-z0-9]{24}$"
        },
        "requirements": {
          "type": "object",
          "properties": {
            "memory_mb": { "type": "integer", "minimum": 256, "maximum": 4096, "default": 512 },
            "timeout_ms": { "type": "integer", "minimum": 60000, "maximum": 3600000, "default": 3600000 }
          }
        }
      }
    },

    "AllocationResponse": {
      "type": "object",
      "required": ["allocation_id", "runtime_id", "host_id", "bind_token", "estimated_ready_ms"],
      "properties": {
        "allocation_id": { "type": "string" },
        "runtime_id": { "type": "string", "pattern": "^rt_[a-z0-9]{16}$" },
        "host_id": { "type": "string" },
        "bind_token": { "type": "string" },
        "estimated_ready_ms": { "type": "integer" }
      }
    },

    "RuntimeHealth": {
      "type": "object",
      "required": ["status", "uptime_ms", "memory_mb", "last_heartbeat_ms"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["warming", "ready", "busy", "draining", "dead"]
        },
        "session_id": { "type": ["string", "null"] },
        "uptime_ms": { "type": "integer" },
        "memory_mb": { "type": "integer" },
        "last_heartbeat_ms": { "type": "integer" }
      }
    },

    "PoolStatus": {
      "type": "object",
      "required": ["total_runtimes", "warm_available", "busy", "draining"],
      "properties": {
        "total_runtimes": { "type": "integer" },
        "warm_available": { "type": "integer" },
        "busy": { "type": "integer" },
        "draining": { "type": "integer" },
        "host_status": {
          "type": "object",
          "properties": {
            "host_id": { "type": "string" },
            "runtimes": { "type": "integer" },
            "cpu_percent": { "type": "number" },
            "memory_percent": { "type": "number" }
          }
        }
      }
    },

    "RuntimeBindRequest": {
      "type": "object",
      "description": "Sent by runtime process to gateway to bind to a session",
      "required": ["session_id", "runtime_id", "bind_token"],
      "properties": {
        "session_id": { "type": "string" },
        "runtime_id": { "type": "string" },
        "bind_token": { "type": "string" },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "AdmissionResult": {
      "type": "object",
      "required": ["allowed"],
      "properties": {
        "allowed": { "type": "boolean" },
        "reason": {
          "type": "string",
          "enum": ["capacity_exceeded", "memory_pressure", "user_limit_exceeded", "draining"]
        },
        "queue_position": { "type": "integer" },
        "estimated_wait_ms": { "type": "integer" }
      }
    }
  }
}
